#!/usr/bin/env bash
# worksesh — Create or attach to a tmux session for a project directory
#
# Usage:
#   worksesh              # Use current directory
#   worksesh ~/code/vesta # Use specified directory
#   worksesh -s           # Also launch claude-squad in a second window
#
# Creates a session named after the directory.
# Use prefix+y for Claude popup, prefix+u for claude-squad popup.

set -euo pipefail

SQUAD=false

# Parse flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--squad) SQUAD=true; shift ;;
        *) PROJECT_DIR="$1"; shift ;;
    esac
done

PROJECT_DIR="${PROJECT_DIR:-.}"

# Resolve to absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
SESSION_NAME="$(basename "$PROJECT_DIR" | tr '.' '-')"

# If session exists, just attach
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$SESSION_NAME"
    else
        tmux attach-session -t "$SESSION_NAME"
    fi
    exit 0
fi

# Create new session
tmux new-session -d -s "$SESSION_NAME" -n "edit" -c "$PROJECT_DIR"

# Optionally launch claude-squad
if [[ "$SQUAD" == true ]]; then
    tmux new-window -t "$SESSION_NAME" -n "squad" -c "$PROJECT_DIR" "claude-squad"
    tmux select-window -t "${SESSION_NAME}:edit"
fi

# Attach
if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION_NAME"
else
    tmux attach-session -t "$SESSION_NAME"
fi
