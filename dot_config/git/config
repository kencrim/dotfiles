[core]
    editor = nvim
    pager = delta
    hooksPath = ~/.config/git/hooks

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[merge]
    conflictstyle = zdiff3

[diff]
    algorithm = histogram
    colorMoved = default

[rerere]
    enabled = true
